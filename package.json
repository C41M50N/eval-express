{
  "name": "@cbuff/eval-express",
  "version": "0.3.2",
  "description": "Type-safe eval builder with scorer pipelines and run planning",
  "keywords": [
    "ai",
    "eval",
    "evaluation",
    "llm",
    "scoring",
    "typescript"
  ],
  "license": "MIT",
  "author": "Charles Buffington",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/C41M50N/eval-express.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./score-helpers": {
      "types": "./dist/score-helpers/index.d.ts",
      "import": "./dist/score-helpers/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "bump": "bumpp"
  },
  "dependencies": {
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
